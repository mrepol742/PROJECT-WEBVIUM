            a:maxLines="1"
            a:textSize="@dimen/c" />

        <TextView
            a:id="@id/e13"
            a:layout_width="fill_parent"
            a:layout_height="wrap_content"
            a:ellipsize="end"
            a:maxLines="1"
            a:textSize="@dimen/c" />

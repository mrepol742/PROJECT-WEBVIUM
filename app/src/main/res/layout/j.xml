<ScrollView xmlns:a="http://schemas.android.com/apk/res/android"

    a:layout_width="fill_parent"

    a:layout_height="wrap_content">

    <LinearLayout
        a:layout_width="fill_parent"
        a:layout_height="wrap_content"
        a:layout_marginTop="10dp"
        a:orientation="vertical"
        a:paddingStart="?m"
        a:paddingEnd="?m">

        <TextView
            a:id="@id/a5"
            a:layout_width="fill_parent"
            a:layout_height="wrap_content"
            a:ellipsize="end"
            a:labelFor="@id/d1"
            a:maxLines="1"
            a:textSize="@dimen/c" />

        <com.droidmj.webvium.EDIT
            a:id="@id/d1"
            a:layout_width="fill_parent"
            a:layout_height="wrap_content"
            a:imeOptions="actionGo|flagNoFullscreen"
            a:inputType="textAutoCorrect"
            a:textSize="@dimen/c" />

        <TextView
            a:id="@id/b9"
            a:layout_width="fill_parent"
            a:layout_height="wrap_content"
            a:layout_marginTop="10dp"
            a:ellipsize="end"
            a:maxLines="1"
            a:textSize="@dimen/c" />

        <HorizontalScrollView
            a:id="@id/c13"
            a:layout_width="fill_parent"
            a:layout_height="wrap_content">

            <TextView
                a:id="@id/d2"
                a:layout_width="wrap_content"
                a:layout_height="wrap_content"
                a:ellipsize="end"
                a:maxLines="1"
                a:scrollHorizontally="true"
                a:textIsSelectable="true"
                a:textSize="@dimen/c" />
        </HorizontalScrollView>

        <TextView

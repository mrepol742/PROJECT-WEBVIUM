<LinearLayout xmlns:a="http://schemas.android.com/apk/res/android"
    a:layout_width="fill_parent"
    a:layout_height="fill_parent"
    a:orientation="vertical"
    a:paddingStart="?m"

    a:paddingEnd="?m">

    <TextView
        a:id="@id/l3"
        a:layout_width="wrap_content"
        a:layout_height="wrap_content"
        a:layout_marginTop="10dp"
        a:ellipsize="end"
        a:labelFor="@id/l4"
        a:maxLines="1"
        a:textSize="@dimen/c" />

    <com.droidmj.webvium.EDIT
        a:id="@id/l4"
        a:layout_width="fill_parent"
        a:layout_height="wrap_content"
        a:inputType="text"
        a:textSize="@dimen/c" />

    <TextView
        a:id="@id/l5"
        a:layout_width="fill_parent"
        a:layout_height="wrap_content"
        a:layout_marginTop="10dp"
        a:ellipsize="end"
        a:maxLines="1"
        a:textSize="@dimen/c" />

    <HorizontalScrollView
        a:layout_width="fill_parent"
        a:layout_height="wrap_content"

        >

        <TextView
            a:id="@id/l6"
            a:layout_width="wrap_content"
            a:layout_height="wrap_content"
            a:ellipsize="end"
            a:maxLines="1"
            a:scrollHorizontally="true"
            a:textSize="@dimen/c" />
    </HorizontalScrollView>

</LinearLayout>
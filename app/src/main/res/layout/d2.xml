<LinearLayout xmlns:a="http://schemas.android.com/apk/res/android"
    a:id="@id/o24"
    a:layout_width="match_parent"
    a:layout_height="match_parent"
    a:orientation="vertical">

    <Toolbar
        a:id="@id/i2"
        a:layout_width="match_parent"
        a:layout_height="wrap_content"
        a:elevation="5dp"
        a:minHeight="@dimen/o">

        <RelativeLayout
            a:layout_width="match_parent"
            a:layout_height="wrap_content">

            <TextView
                a:id="@id/i3"
                a:layout_width="wrap_content"
                a:layout_height="wrap_content"
                a:layout_alignParentStart="true"
                a:layout_marginStart="10dp"
                a:layout_marginEnd="10dp"
                a:layout_toStartOf="@id/k3"
                a:ellipsize="end"
                a:gravity="center_vertical"
                a:maxLines="1"
                a:textSize="@dimen/a" />

            <ImageView
                a:id="@id/k3"
                a:layout_width="24dp"
                a:layout_height="24dp"
                a:layout_alignParentEnd="true"
                a:layout_centerInParent="true"
                a:layout_marginStart="15dp"
                a:layout_marginEnd="15dp"
                a:contentDescription="@string/x39" />
        </RelativeLayout>
    </Toolbar>


    <TextView
        a:id="@id/h14"
        a:layout_width="match_parent"
        a:layout_height="wrap_content"
        a:layout_marginTop="10dp"
        a:ellipsize="end"
        a:labelFor="@id/b15"
        a:maxLines="1"
        a:paddingStart="?m"
        a:paddingEnd="?m"
        a:textSize="@dimen/c" />

    <AutoCompleteTextView
        a:id="@id/b15"
        a:layout_width="match_parent"
        a:layout_height="40dp"
        a:layout_marginStart="?m"
        a:layout_marginEnd="?m"
        a:imeOptions="flagNoFullscreen"
        a:inputType="text"
        a:textSize="@dimen/c" />

    <TextView
        a:id="@id/h15"
        a:layout_width="match_parent"
        a:layout_height="wrap_content"
        a:layout_marginTop="10dp"
        a:labelFor="@id/h16"
        a:paddingStart="?m"
        a:paddingEnd="?m"
        a:textSize="@dimen/c" />

    <EditText
        a:id="@id/h16"
        a:layout_width="match_parent"
        a:layout_height="wrap_content"
        a:layout_marginStart="?m"
        a:layout_marginEnd="?m"
        a:gravity="top"
        a:imeOptions="flagNoFullscreen"
        a:inputType="textMultiLine"
        a:textSize="@dimen/c" />


</LinearLayout>